meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{email}}",
    "password": "{{password}}"
  }
}

script:post-response {
  if (res.getStatus() === 200) {
    bru.setEnvVar("token", res.getBody().token);
  }
}

tests {
  test("got token", function () {
    expect(res.getBody().token).to.be.a("string");
  });
}