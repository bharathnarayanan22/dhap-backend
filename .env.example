# Copy to .env and fill in real values. .env is gitignored — never commit real secrets.

# MongoDB Atlas connection string (mongodb+srv://user:pass@cluster.../?appName=...)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/?appName=Cluster0
MONGODB_DATABASE=dhap

# Long random string (>= 32 chars) used to sign JWTs
JWT_SECRET=change-me-to-a-long-random-secret-string

# Cloudinary connection string from the Cloudinary dashboard
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
